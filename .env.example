# Genesis 配置文件示例
# 复制此文件为 .env 并填写实际值

# ==================== 连接配置 ====================
# NapCat WebSocket 地址
NAPCAT_WS_URL=ws://localhost:6702
# 媒体消息和普通文件上传超时
# NAPCAT_MEDIA_SEND_TIMEOUT_MS=30000
# NAPCAT_FILE_SEND_TIMEOUT_MS=120000

# Web 控制台监听地址。`127.0.0.1` 仅本机；`::` 可同时监听 IPv6/双栈
WEB_HOST=127.0.0.1
# Web 控制台访问密码。设置后，页面、API、日志 WS 都需要先登录
# WEB_PASSWORD=replace-with-a-strong-password
# 如需跨机或脚本直接访问 /api 与 /ws/logs，可额外配置 Bearer token
# WEB_API_TOKEN=replace-with-a-long-random-string

# ==================== 管理员配置 ====================
# 管理员 QQ 号（逗号分隔）
ADMIN_QQ=123456789,987654321
# 机器人 QQ 号
BOT_QQ=2086702098

# ==================== 主 LLM 配置 ====================
# 默认 LLM 配置（其他 LLM 未配置时使用此配置）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# ==================== 各组件独立 LLM 配置 ====================
# 格式：{组件}_LLM_BASE_URL, {组件}_LLM_API_KEY, {组件}_LLM_MODEL
# 未配置时自动使用主 LLM 配置

# 哨兵 Agent（决定是否响应）
# SENTRY_LLM_BASE_URL=
# SENTRY_LLM_API_KEY=
SENTRY_LLM_MODEL=gpt-4o-mini

# 路由 Agent（意图分类）
# ROUTER_LLM_BASE_URL=
# ROUTER_LLM_API_KEY=
ROUTER_LLM_MODEL=grok-4.1-fast

# 技术 Agent（工具调用）
# TECH_LLM_BASE_URL=
# TECH_LLM_API_KEY=
TECH_LLM_MODEL=gemini-3-flash-preview

# 自动表情判定
# AUTO_MEME_LLM_BASE_URL=
# AUTO_MEME_LLM_API_KEY=
AUTO_MEME_LLM_MODEL=gemini-3-flash-preview

# 人设 Agent（闲聊）
# PERSONA_LLM_BASE_URL=
# PERSONA_LLM_API_KEY=
PERSONA_LLM_MODEL=gemini-3-flash-preview

# 识图 Agent
# VISION_LLM_BASE_URL=
# VISION_LLM_API_KEY=
VISION_LLM_MODEL=gemini-3-flash-preview

# 画像 Agent（用户分析）
# PROFILER_LLM_BASE_URL=
# PROFILER_LLM_API_KEY=
PROFILER_LLM_MODEL=gpt-4o-mini

# 向量 Embedding
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-004

# ==================== 绘图 API 配置 ====================
# 独立的绘图 API（默认 yuanplus.chat）
DRAW_LLM_BASE_URL=https://senapi.fun/v1
DRAW_LLM_API_KEY=sk-xxx
DRAW_LLM_MODEL=anishadow-v10-plus
# 兼容旧键：DRAW_API_KEY / DRAW_MODEL
# 图片发送模式可单独覆盖；留空时继承全局 FILE_SEND_MODE
# DRAW_IMAGE_SEND_MODE=local

# ==================== Banana 绘图配置 ====================
# 高级改图/手办化/四格漫画/自拍化工具
# BANANA_DRAW_LLM_PROVIDER_ID=
# BANANA_DRAW_LLM_BASE_URL=
# BANANA_DRAW_LLM_API_KEY=
# BANANA_DRAW_LLM_MODEL=
# BANANA_DRAW_CHAT_MODEL=        # 留空时跟随 BANANA_DRAW_LLM_MODEL
# BANANA_DRAW_IMAGE_MODEL=       # 留空时跟随 BANANA_DRAW_LLM_MODEL
# BANANA_DRAW_API_MODE=auto
# BANANA_DRAW_PREFER_FOR_TEXT2IMAGE=false
# BANANA_DRAW_IMAGE_INPUT_MODE=url_array
# BANANA_DRAW_IMAGE_SIZE=2160x3840
# BANANA_DRAW_IMAGE_QUALITY=
# BANANA_DRAW_IMAGE_BACKGROUND=auto
# BANANA_DRAW_OUTPUT_FORMAT=png
# BANANA_DRAW_SEND_MODE=local      # 留空时继承全局 FILE_SEND_MODE

# ==================== 技能自维护 LLM 配置 ====================
# 造技能 create_skill
# CREATE_SKILL_LLM_BASE_URL=
# CREATE_SKILL_LLM_API_KEY=
CREATE_SKILL_LLM_MODEL=gpt-5.3-codex

# 管技能 manage_skill
# MANAGE_SKILL_LLM_BASE_URL=
# MANAGE_SKILL_LLM_API_KEY=
MANAGE_SKILL_LLM_MODEL=gpt-5.3-codex

# ==================== Agent 功能开关 ====================
# 全部默认 true，设置 false 可禁用

# 哨兵 Agent（false 时始终响应被 @ 的消息）
AGENT_SENTRY_ENABLED=true
# Router LLM 分析（false 时仅用规则匹配）
AGENT_ROUTER_LLM_ENABLED=true
# 用户画像分析
AGENT_PROFILER_ENABLED=true
# VectorDB 记忆存储
AGENT_VECTORDB_ENABLED=true
# 情感分析
AGENT_EMOTION_ENABLED=true

# ==================== 工具功能开关 ====================
# 全部默认 true，设置 false 可禁用

TOOL_LIKE_ENABLED=true
TOOL_PROFILE_ENABLED=true
TOOL_POKE_ENABLED=true
TOOL_VISION_ENABLED=true
TOOL_WEATHER_ENABLED=true
TOOL_DRAW_ENABLED=true

# ==================== 其他配置 ====================
# 工具响应是否经过 Persona 润色
TOOL_ENHANCE_RESPONSE=true
# 预计工具回复较慢时，先发送一条等待提示
PENDING_REPLY_ENABLED=true
# 等待提示是否先走 Persona LLM 生成人设口吻，失败再回退模板
PENDING_REPLY_PERSONA_ENABLED=true
# Persona 等待提示生成超时（毫秒）
PENDING_REPLY_PERSONA_TIMEOUT_MS=6000
# 超过该估算耗时才发送等待提示（毫秒）
PENDING_REPLY_THRESHOLD_MS=12000
# 同一会话等待提示冷却时间（毫秒）
PENDING_REPLY_COOLDOWN_MS=25000
# Tech Agent 工具调用模式: prompt | function_calling
TECH_TOOL_MODE=function_calling

# 消息防抖延迟（毫秒）
DEBOUNCE_DELAY_MS=1500
# 记忆窗口大小
MEMORY_WINDOW_SIZE=10

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
